{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information stored in Firestore",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The user's full name" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "createdAt": { "type": "string", "format": "date-time", "description": "ISO timestamp of account creation" }
      },
      "required": ["name", "email", "createdAt"]
    },
    "Booking": {
      "title": "Booking",
      "description": "An appointment booked by a user",
      "type": "object",
      "properties": {
        "patientName": { "type": "string", "description": "Name of the patient" },
        "email": { "type": "string", "format": "email", "description": "Contact email" },
        "phone": { "type": "string", "description": "Contact phone number" },
        "departmentId": { "type": "string", "description": "ID of the medical department" },
        "doctorId": { "type": "string", "description": "ID of the assigned doctor" },
        "date": { "type": "string", "format": "date", "description": "Date of appointment" },
        "time": { "type": "string", "description": "Selected time slot" },
        "reason": { "type": "string", "description": "Reason for the visit" },
        "userId": { "type": "string", "description": "The UID of the user who made the booking" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"], "description": "Current status of the booking" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Server-side timestamp of the booking" }
      },
      "required": ["patientName", "email", "phone", "departmentId", "date", "time", "userId", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection of patient appointments"
    }
  }
}
